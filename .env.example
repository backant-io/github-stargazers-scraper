# GitHub API authentication token
# Required scopes: read:user, public_repo (or repo for private repos)
GITHUB_TOKEN=your_github_token_here

# PostgreSQL connection string (Neon/PlanetScale)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Upstash Redis (HTTP-based, Cloudflare Workers compatible)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# Secret for API key hashing
API_KEY_SECRET=your_api_key_secret_here
